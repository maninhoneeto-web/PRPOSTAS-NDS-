rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for Proposal
    function isValidProposal(data) {
      return data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 200
        && data.data is map 
        && data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      
      match /proposals/{proposalId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidProposal(request.resource.data);
        allow update: if isOwner(userId) && isValidProposal(request.resource.data)
          && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'data', 'updatedAt']));
        allow delete: if isOwner(userId);
      }
    }
  }
}
